# Copiar a `.env` y ajustar valores. Todas las variables llevan el prefijo VENTAS360_.

# Entorno de ejecución: dev | test | prod
VENTAS360_ENTORNO=dev

# URL de la base de datos (SQLAlchemy async).
# SQLite (default para desarrollo):
VENTAS360_DATABASE_URL=sqlite+aiosqlite:///./data/ventas360.db
# PostgreSQL (producción / cuando el sistema escale):
# VENTAS360_DATABASE_URL=postgresql+asyncpg://ventas360:ventas360@db:5432/ventas360

# Secreto para firmar los JWT. CAMBIAR en producción (ej: openssl rand -hex 32).
VENTAS360_JWT_SECRETO=cambiar-este-secreto-en-produccion

# Minutos de validez del token de acceso.
VENTAS360_JWT_EXPIRACION_MINUTOS=480

# Orígenes permitidos para CORS (separados por coma; credentials → origin explícito).
VENTAS360_CORS_ORIGINS=http://localhost:4200,http://localhost:4201

# Sembrar datos de demo al iniciar si la base está vacía (solo dev).
VENTAS360_SEED_AL_INICIAR=true

# Exponer la API como servidor MCP para agentes de IA (requiere: poetry install --with mcp).
VENTAS360_MCP_HABILITADO=false
